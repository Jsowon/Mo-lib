    "/search/music": {
      "get": {
        "tags": ["search"],
        "summary": "음악 검색",
        "description": "Spotify에서 음악을 검색합니다. API 장애 시 빈 결과와 error 메시지를 반환합니다.",
        "operationId": "search_music_search_music_get",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "검색어",
              "title": "Q"
            },
            "description": "검색어"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 10,
              "minimum": 1,
              "description": "결과 수 (최대 10, Spotify 개발자 앱 제한)",
              "default": 10,
              "title": "Limit"
            },
            "description": "결과 수 (최대 10, Spotify 개발자 앱 제한)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MusicSearchResponse" }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
