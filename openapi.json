  "components": {
    "schemas": {
      "AIRecommendationItem": {
        "properties": {
          "title": { "type": "string", "title": "Title" },
          "reason": { "type": "string", "title": "Reason" },
          "tags": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Tags"
          },
          "connection_keyword": {
            "type": "string",
            "title": "Connection Keyword"
          }
        },
        "type": "object",
        "required": ["title", "reason", "tags", "connection_keyword"],
        "title": "AIRecommendationItem"
      },
      "ArchiveNodeResponse": {
        "properties": {
          "id": { "type": "string", "title": "Id" },
          "map_id": { "type": "string", "title": "Map Id" },
          "domain": { "type": "string", "title": "Domain" },
          "external_id": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "External Id"
          },
          "title": { "type": "string", "title": "Title" },
          "description": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Description"
          },
          "image_url": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Image Url"
          },
          "emotion_tags": {
            "anyOf": [
              { "items": { "type": "string" }, "type": "array" },
              { "type": "null" }
            ],
            "title": "Emotion Tags"
          },
          "is_root": { "type": "boolean", "title": "Is Root" },
          "step_order": { "type": "integer", "title": "Step Order" },
          "is_archived": { "type": "boolean", "title": "Is Archived" }
        },
        "type": "object",
        "required": [
          "id",
          "map_id",
          "domain",
          "external_id",
          "title",
          "description",
          "image_url",
          "emotion_tags",
          "is_root",
          "step_order",
          "is_archived"
        ],
        "title": "ArchiveNodeResponse"
      },
      "BookSearchResponse": {
        "properties": {
          "results": {
            "items": { "$ref": "#/components/schemas/ContentItem" },
            "type": "array",
            "title": "Results"
          },
          "total": { "type": "integer", "title": "Total" },
          "error": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Error"
          }
        },
        "type": "object",
        "required": ["results", "total"],
        "title": "BookSearchResponse"
      },
      "ContentItem": {
        "properties": {
          "domain": { "type": "string", "title": "Domain" },
          "title": { "type": "string", "title": "Title" },
          "description": { "type": "string", "title": "Description" },
          "genre": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Genre"
          },
          "creator": { "type": "string", "title": "Creator" },
          "keywords": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Keywords"
          },
          "thumbnail_url": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Thumbnail Url",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "domain",
          "title",
          "description",
          "genre",
          "creator",
          "keywords"
        ],
        "title": "ContentItem"
      },
      "EdgeResponse": {
        "properties": {
          "id": { "type": "string", "title": "Id" },
          "map_id": { "type": "string", "title": "Map Id" },
          "source_node_id": { "type": "string", "title": "Source Node Id" },
          "target_node_id": { "type": "string", "title": "Target Node Id" },
          "reason": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Reason"
          }
        },
        "type": "object",
        "required": [
